# Workspace API (obrigatório em produção)
NEXT_PUBLIC_USE_WORKSPACE_API=true
NEXT_PUBLIC_WORKSPACE_API_URL=https://api.innexar.com.br

# Link para site principal (usado no login "Começar agora")
NEXT_PUBLIC_SITE_URL=https://innexar.com.br

# Mercado Pago - chave pública para Bricks (Pix e boleto no portal)
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...

# Stripe - opcional; deixe vazio no stack BR se o workspace usar apenas Mercado Pago.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
